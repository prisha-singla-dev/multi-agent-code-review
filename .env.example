# ─── CodeSentinel .env ────────────────────────────────────────────────────────
# Copy this to .env — NEVER commit .env to git

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = instant mock responses, zero API calls (for demos)
# false = real LLM calls (needs GEMINI_API_KEY or OPENROUTER_API_KEY)
DEMO_MODE=false

# ── LLM — pick ONE (or both, Gemini is tried first) ──────────────────────────

# Option A: Google Gemini Flash (free tier — 15 req/min, 1M tokens/day)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: OpenRouter FREE models — no billing card needed
# Sign up: https://openrouter.ai  → Dashboard → Keys → Create key
# Free models: meta-llama/llama-3.1-8b-instruct:free
#              mistralai/mistral-7b-instruct:free
#              google/gemma-2-9b-it:free
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=your_openrouter_model_here

# ── GitHub Integration ────────────────────────────────────────────────────────
# Token: https://github.com/settings/tokens/new
# Scopes: repo (full) — needed to read PR diffs + post comments
GITHUB_TOKEN=ghp_your_token_here

# Webhook secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Paste same value in GitHub → repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_random_hex_secret_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
