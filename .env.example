# ─── CodeSentinel .env ────────────────────────────────────────────
# Copy to .env — never commit .env to git

# ── Mode ──────────────────────────────────────────────────────────
# true  = instant mock responses, no API quota used (demo/testing)
# false = real Gemini API calls
DEMO_MODE=true

# ── Gemini (free tier) ────────────────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GitHub Token ──────────────────────────────────────────────────
# Create: https://github.com/settings/tokens/new
# Scopes needed: repo  (to read PR diffs + post comments)
GITHUB_TOKEN=ghp_your_token_here

# ── Webhook Secret ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Paste the SAME value into GitHub → repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_random_32char_hex_here

# ── Server (usually don't need to change) ─────────────────────────
PORT=8000
HOST=0.0.0.0
